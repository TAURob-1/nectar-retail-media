{
  "name": "nectar-retail-media",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "cd api && python3 -m uvicorn main:app --host 0.0.0.0 --port ${PORT:-8001}",
    "build": "pip install -r api/requirements.txt && cd ui && npm install && npm run build",
    "dev:proxy": "node server.js",
    "dev:ui": "cd ui && npm run dev",
    "install:ui": "cd ui && npm install",
    "build:ui": "cd ui && npm run build"
  },
  "dependencies": {
    "express": "^4.19.2",
    "http-proxy-middleware": "^3.0.3"
  }
}
